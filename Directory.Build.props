<Project>

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Deterministic>true</Deterministic>
    <!-- Mac hat nur net10-Runtime; net9-Targets per RollForward lokal lauffaehig. codespace laeuft nativ auf net9. -->
    <RollForward>Major</RollForward>
  </PropertyGroup>

  <PropertyGroup Label="Metadata">
    <Authors>Cong Nguyen</Authors>
    <Product>RalphForge</Product>
    <RepositoryUrl>https://github.com/Koschnag/ralph-forge</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

</Project>
